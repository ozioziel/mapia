# ============================================================
# Mapia Backend - Variables de entorno (EJEMPLO)
# Copiar a .env y completar. NUNCA commitear el .env real.
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
# Orígenes permitidos para CORS, separados por coma (* solo para dev)
CORS_ORIGINS=*

# --- Base de datos (PostgreSQL + PostGIS) ---
# Desarrollo local (PostgreSQL nativo):
#DB_HOST=localhost
#DB_PORT=5432
#DB_USERNAME=mapia_user
#DB_PASSWORD=mapia_password
#DB_DATABASE=mapia_db
#DB_SSL=false
# Ejecutar migraciones automáticamente al arrancar (en prod prefiérelo como job)
DB_RUN_MIGRATIONS=true

# --- Supabase (free tier, PostGIS incluido) ---
# Usar el "Session pooler" (Connect -> Session mode) de tu proyecto Supabase.
# Reemplaza los valores de arriba por estos cuando uses Supabase:
DB_HOST=aws-0-<region>.pooler.supabase.com
DB_PORT=5432
DB_USERNAME=postgres.<project-ref>
DB_PASSWORD=<tu-db-password>
DB_DATABASE=postgres
DB_SSL=true
DB_RUN_MIGRATIONS=false   # corre las migraciones tú mismo, no en cada arranque

# --- JWT ---
JWT_ACCESS_SECRET=change_me_access
JWT_REFRESH_SECRET=change_me_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Storage ---
# local = guarda en disco (dev) | gcs = Google Cloud Storage (prod)
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=uploads
# URL pública base para servir archivos locales en dev
STORAGE_PUBLIC_URL=http://localhost:3000/static

# --- Google Cloud ---
GCP_PROJECT_ID=
GCP_REGION=
GCS_BUCKET_NAME=mapia-media

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_GEOCODING_ENABLED=true
GOOGLE_MAPS_PLACES_ENABLED=true

# --- Geo / negocio ---
DEFAULT_RADIUS_KM=3
MAX_RADIUS_KM=50

# --- Rate limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=120
