# ============================================================
# Mapia Backend - variables de entorno de ejemplo
# Copiar a .env y completar. Nunca commitear el .env real.
# ============================================================

# --- App ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
# Produccion: usar dominios concretos separados por coma, no *.
CORS_ORIGINS=*

# --- Base de datos local (PostgreSQL + PostGIS) ---
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=mapia_user
DB_PASSWORD=mapia_password
DB_DATABASE=mapia_db
DB_SSL=false
DB_RUN_MIGRATIONS=true

# --- Produccion con Supabase Session Pooler ---
# DB_HOST=aws-0-<region>.pooler.supabase.com
# DB_PORT=5432
# DB_USERNAME=postgres.<project-ref>
# DB_PASSWORD=<SUPABASE_DB_PASSWORD>
# DB_DATABASE=postgres
# DB_SSL=true
# DB_RUN_MIGRATIONS=false

# --- JWT ---
JWT_ACCESS_SECRET=<JWT_ACCESS_SECRET>
JWT_REFRESH_SECRET=<JWT_REFRESH_SECRET>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Storage ---
# local = disco local (dev) | supabase = Supabase Storage | gcs = Google Cloud Storage
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=uploads
STORAGE_PUBLIC_URL=http://localhost:3000/static

# Supabase Storage, solo si STORAGE_DRIVER=supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_STORAGE_BUCKET=alert-images

# Google Cloud Storage, solo si STORAGE_DRIVER=gcs
GCP_PROJECT_ID=
GCP_REGION=
GCS_BUCKET_NAME=mapia-media

# --- Google Maps / Places / Geocoding ---
# GOOGLE_MAPS_API_KEY puede ser una key de cliente restringida por app/dominio.
# GOOGLE_MAPS_SERVER_API_KEY debe quedarse solo en backend y estar restringida por API/IP.
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_SERVER_API_KEY=
GOOGLE_MAPS_GEOCODING_ENABLED=true
GOOGLE_MAPS_PLACES_ENABLED=true

# --- IA / noticias ---
GROQ_API=
GEMINI_API=

# --- Geo / negocio ---
DEFAULT_RADIUS_KM=3
MAX_RADIUS_KM=50

# --- Rate limiting ---
THROTTLE_TTL=60
THROTTLE_LIMIT=120
